# Base URL for the Hidden Grain read-only API.
# Dev default: http://localhost:3000/api/v1
# Same-origin deployments: /api
VITE_HG_API_BASE=http://localhost:3000/api/v1

# Optional per-request timeout in milliseconds. Defaults to 10000.
VITE_HG_REQUEST_TIMEOUT_MS=10000

# Optional participant-facing origin used by SharePanel to build the public
# `/e/:id` link + QR. Must be the PUBLISHED origin (never the preview host):
# preview URLs are auth-gated by the platform and return HTTP 401 to any
# unauthenticated participant. When empty, SharePanel falls back to
# `window.location.origin` and warns if it detects a preview host.
# Example: VITE_HG_PUBLIC_BASE=https://hidden-grain-insight.lovable.app
VITE_HG_PUBLIC_BASE=
